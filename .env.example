# API Key Gemini dari Google AI Studio
GEMINI_API_KEY=MASUKKAN_API_KEY_GEMINI_DI_SINI

# JID grup WhatsApp yang bot boleh merespon (pisah dengan koma jika lebih dari satu)
# Format JID grup: 120363XXXXXXXXXX@g.us
# Cara cari JID: jalankan bot, kirim pesan di grup, lihat log "Pesan masuk dari grup"
ALLOWED_GROUP_JID=120363197099910381@g.us

# =============================================
# DOKU Checkout (Fitur Donasi)
# =============================================
# Cukup isi Client ID dan Secret Key dari DOKU Dashboard.
# Jika tidak diisi, bot tetap berjalan normal tanpa fitur donasi.

# Client ID dari DOKU Dashboard (Menu: Settings > API Keys)
DOKU_CLIENT_ID=

# Secret Key dari DOKU Dashboard (klik "Reveal Key" lalu copy)
DOKU_SECRET_KEY=

# Set ke "true" untuk sandbox, "false" untuk production
DOKU_SANDBOX=true

# Port untuk webhook server
DOKU_WEBHOOK_PORT=8080

# URL publik webhook (isi dengan URL ngrok atau domain production)
# Contoh: https://abc123.ngrok-free.app/doku/webhook
DOKU_WEBHOOK_URL=

# =============================================
# Trivia Quiz Otomatis
# =============================================
# Bot akan mengirim pertanyaan trivia random setiap sekian menit.
# Member menjawab dengan mengetik A/B/C/D.

# Set ke "true" untuk mengaktifkan fitur trivia
TRIVIA_ENABLED=false

# Interval antar pertanyaan (dalam menit, default: 30)
TRIVIA_INTERVAL_MINUTES=30

# Waktu untuk menjawab (dalam detik, default: 60)
TRIVIA_ANSWER_TIMEOUT_SECONDS=60

# =============================================
# Poker Game (Texas Hold'em)
# =============================================
# Bot akan mengelola permainan poker interaktif di grup.
# Player join lobby, lalu bermain poker via pesan teks.

# Set ke "true" untuk mengaktifkan fitur poker
POKER_ENABLED=false

# Chip awal setiap pemain per sesi (default: 1000)
POKER_STARTING_CHIPS=1000

# Blind kecil dan besar (default: 10/20)
POKER_SMALL_BLIND=10
POKER_BIG_BLIND=20

# Waktu maksimal per giliran sebelum auto-fold (dalam detik, default: 60)
POKER_TURN_TIMEOUT_SECONDS=60

# Jeda sebelum ronde berikutnya dimulai otomatis (dalam detik, default: 5)
POKER_AUTO_NEXT_ROUND_SECONDS=5
TRIVIA_REWARD=500

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME